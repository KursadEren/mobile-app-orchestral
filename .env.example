# ============================================
# ORKESTRAL AI - YAPILANDIRMA DOSYASI
# ============================================

# --------------------------------------------
# ANTHROPIC API KEY (Zorunlu)
# --------------------------------------------
# Claude AI'yı kullanmak için gerekli
# https://console.anthropic.com adresinden alabilirsin
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --------------------------------------------
# GITHUB AYARLARI (Batch mod için gerekli)
# --------------------------------------------
# 10 uygulama üretip GitHub'a yüklemek için gerekli
# Token almak için: https://github.com/settings/tokens
# → Generate new token (classic)
# → "repo" yetkisini seç
# → Token'ı kopyala

GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username
